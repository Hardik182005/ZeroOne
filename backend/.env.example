# ZeroOne — Environment Variables
# Copy this to .env and fill in your real keys

# AI — Claude (Primary)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# AI — Gemini Flash (Fallback + PDF)
GEMINI_API_KEY=your_gemini_api_key_here

# Voice — ElevenLabs TTS
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# Data — Anakin Wire API (all 7 market connectors)
ANAKIN_API_KEY=your_anakin_wire_api_key_here

# Cache — Redis
REDIS_URL=redis://localhost:6379

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,https://zeroonone.web.app,https://zeroonone.firebaseapp.com

# App settings
APP_ENV=development
MAX_WIRE_TIMEOUT=10
CACHE_TTL_STOCK=300
CACHE_TTL_FUNDAMENTALS=3600

# Optional — AI fallbacks (keep blank if not using)
GROK_API_KEY=
OPENAI_API_KEY=
