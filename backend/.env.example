# ZeroOne — Environment Variables
# Copy this file to .env and fill in your real keys

# ── AI — Groq (primary verdict engine, fast LPU inference) ───────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── AI — Gemini Flash (PDF reports + fallback) ───────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Voice — ElevenLabs TTS ───────────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# ── Data — Anakin Wire API key ───────────────────────────────────────────────
# Get from: https://app.anakin.ai → Profile → API Keys
ANAKIN_API_KEY=ask_your_anakin_api_key_here

# ── Anakin Wire Connector IDs ────────────────────────────────────────────────
# Each connector is a separate "Wire" app in Anakin.
# Get the numeric ID from: app.anakin.ai → your Wire app → API tab → "Chatbot ID"
# Leave blank to fall back to mock data for that connector.
ANAKIN_ID_NSE_INDIA=
ANAKIN_ID_BSE_INDIA=
ANAKIN_ID_SCREENER=
ANAKIN_ID_ET=
ANAKIN_ID_MC=
ANAKIN_ID_FG=
ANAKIN_ID_GT=
ANAKIN_ID_ST=

# ── Cache — Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── CORS origins ──────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,https://zeroone-in.web.app,https://zeroonone.web.app

# ── App settings ──────────────────────────────────────────────────────────────
APP_ENV=development
MAX_WIRE_TIMEOUT=10
CACHE_TTL_STOCK=1800
CACHE_TTL_FUNDAMENTALS=3600
